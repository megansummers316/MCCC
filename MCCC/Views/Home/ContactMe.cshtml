@{
	ViewData["Title"] = "Contact Me";
}

<div class="text-center" id="contactMe">
	<h1 class="display-4">Contact Me</h1>
	<form class="contactForm" method="post" asp-controller="Home" asp-action="Contact"> 
		<div>
			<div class="form-group" id="name">
				<label for="name">Name:</label>
				<input type="text" id="name" name="name" placeholder="John Smith" />
			</div>
			<div class="form-group" id="address">
				<label for="address">Address:</label>
				<input type="text" id="address" name="address1" placeholder="123 Front St" class="addressInput" />
				<input type="text" id="address2" name="address2" placeholder="Orillia, ON" class="addressInput" />
				<input type="text" id="address3" name="postalCode" placeholder="L3V 3L5" class="addressInput" />
			</div> 
			<div class="form-group" id="email">
				<label for="email">Email:</label>
				<input type="email" id="email" name="email" placeholder="johnsmith123@example.com" />
			</div>
		</div>
		<div>
			<div class="form-group" id="itemDesc">
				<label for="itemDesc">Item Description:</label>
				<input type="text" id="itemDesc" name="itemDesc" placeholder="Granny Stitch Bucket Hat" />
			</div>
			<div class="form-group" id="colour">
				<label for="colour">Colour(s):</label>
				<input type="text" id="colour" name="colour" placeholder="Fushia" />
			</div>
			<div class="form-group">
				<button type="button" class="newItem">Add another item</button>
			</div>
		</div>
		<div class="form-group">
			<button type="submit">Send</button>
		</div>
	</form>
</div>