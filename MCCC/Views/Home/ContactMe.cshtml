@{
	ViewData["Title"] = "Custom Orders";
}

<div class="text-center" id="contactMe">
	<h1 class="display-4">Custom Orders</h1>
	<form class="contactForm" method="post" asp-controller="Home" asp-action="Contact" enctype="multipart/form-data"> 
		<div>
			<div class="form-group" id="name">
				<label for="name">Name:</label>
				<input type="text" id="name" name="name" placeholder="John Smith" required />
			</div>
			<div class="form-group" id="address">
				<label for="address">Address:</label>
				<input type="text" id="address" name="address1" placeholder="123 Front St" class="addressInput" />
				<input type="text" id="address2" name="address2" placeholder="Orillia, ON" class="addressInput" />
				<input type="text" id="address3" name="postalCode" placeholder="L3V 3L5" class="addressInput" />
			</div> 
			<div class="form-group" id="email">
				<label for="email">Email:</label>
				<input type="email" id="email" name="email" placeholder="johnsmith123@example.com" required />
			</div>
		</div>
		<div class="form-group">
			<p class="descriptive">Be sure to be as descriptive as possible!</p>
		</div>
		<div id="itemContainer">
			<div class="item">
				<div class="form-group">
					<label for="itemDesc">Item Description:</label>
					<input type="text" name="itemDesc" placeholder="Granny Stitch Bucket Hat" required />
				</div>
				<div class="form-group">
					<label for="colour">Colour(s):</label>
					<input type="text" name="colour" placeholder="Fushia" required />
				</div>
				<div class="form-group">
					<label for="referencePhoto">Reference Photo:</label>
					<input type="file" id="referencePhoto" name="referencePhoto" accept="image/*" />
				</div>
			</div>
		</div>
		<div class="form-group">
			<button type="button" class="newItem">Add another item</button>
		</div>
		<div class="form-group">
			<button type="submit" class="submit">Send</button>
		</div>
	</form>
</div>